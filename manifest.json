{
  "manifest_version": 3,
  "name": "Rewind",
  "short_name": "Rewind",
  "version": "0.1.0",
  "description": "Temporarily restores the previous page state after fast SPA navigation, reloads, or accidental click-away.",
  "browser_specific_settings": {
    "gecko": {
      "id": "rewind-extension@example.com",
      "strict_min_version": "121.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "icons": {
    "16": "icons/rewind-16.png",
    "32": "icons/rewind-32.png",
    "48": "icons/rewind-48.png",
    "64": "icons/rewind-64.png",
    "96": "icons/rewind-96.png",
    "128": "icons/rewind-128.png"
  },
  "action": {
    "default_title": "Rewind",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/rewind-16.png",
      "32": "icons/rewind-32.png",
      "64": "icons/rewind-64.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}